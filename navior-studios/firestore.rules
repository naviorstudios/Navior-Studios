rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // Products: Anyone can read, only admins can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: Users can read/write their own profiles, admins can read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Orders: Users can read/write their own orders, admins can read all
    match /orders/{orderId} {
      allow create: if isSignedIn(); 
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Newsletter: Anyone can create (subscribe), only admins can read
    match /newsletter/{email} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
